DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^(.+)\.html$ $1.php [L,QSA,NC]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+?)/?$ $1.php [L,QSA]
</IfModule>
